import tweepy
import asyncio
import logging
from .config import TWITTER_BEARER_TOKEN, TWITTER_KEYWORDS
from .nlp_utils import extract_species, compute_confidence
from .geocode import geocode_location

logger = logging.getLogger(__name__)

class TwitterScraper:
    def __init__(self):
        self.client = tweepy.Client(bearer_token=TWITTER_BEARER_TOKEN)

    async def fetch_recent_tweets(self):
        query = " OR ".join(TWITTER_KEYWORDS)
        # search recent tweets with images
        tweets = self.client.search_recent_tweets(
            query=f"({query}) lang:en -is:retweet has:images",
            max_results=100,
            tweet_fields=["created_at", "geo", "attachments"],
            expansions=["attachments.media_keys", "geo.place_id"],
            media_fields=["url"]
        )
        if not tweets.data:
            return []
        # get media
        media_map = {}
        if tweets.includes and "media" in tweets.includes:
            for media in tweets.includes["media"]:
                media_map[media.media_key] = media.url

        results = []
        for tweet in tweets.data:
            text = tweet.text
            species = extract_species(text)
            if not species:
                continue

            # coordinates
            lat, lng = None, None
            if tweet.geo and tweet.geo.place_id and tweets.includes and "places" in tweets.includes:
                # simplistic: just take first place's bounding box center
                place = next((p for p in tweets.includes["places"] if p.id == tweet.geo.place_id), None)
                if place and place.geo:
                    bbox = place.geo["bbox"]
                    lng = (bbox[0] + bbox[2]) / 2
                    lat = (bbox[1] + bbox[3]) / 2

            # if no coordinates, try to extract location from text
            if lat is None:
                loc_name = extract_location_from_text(text) or species
                lat, lng = await geocode_location(loc_name)

            confidence = compute_confidence(text, has_photo=True, has_geo=(lat is not None))

            results.append({
                "source": "twitter",
                "source_url": f"https://twitter.com/i/web/status/{tweet.id}",
                "content": text,
                "author": tweet.author_id,
                "timestamp": tweet.created_at,
                "image_urls": [media_map.get(key) for key in tweet.attachments.media_keys] if tweet.attachments else [],
                "extracted_species": species,
                "extracted_lat": lat,
                "extracted_lng": lng,
                "confidence_score": confidence,
            })
        return results
